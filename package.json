{
  "name": "portal-honorio-bicalho",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "node scripts/dev-web.mjs",
    "dev:api": "tsx watch api/server.ts",
    "build": "npm run prisma:generate && npm run prisma:deploy && npm run build:web && tsc --noEmit && npm run build:server",
    "build:server": "tsc -p tsconfig.server.json",
    "build:web": "next build",
    "start": "node server.js",
    "start:web": "next start -H 0.0.0.0",
    "start:api": "tsx api/server.ts",
    "prisma:deploy": "node scripts/prisma-deploy.mjs",
    "prisma:generate": "node scripts/prisma-generate.mjs",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "postinstall": "node scripts/prisma-generate.mjs"
  },
  "engines": {
    "node": ">=20 <25"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.16.1",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@react-google-maps/api": "^2.20.4",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "lucide-react": "^0.454.0",
    "next": "^14.2.5",
    "next-auth": "^4.24.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.41",
    "prisma": "^5.16.1",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
